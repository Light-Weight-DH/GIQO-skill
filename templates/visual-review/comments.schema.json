{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GIQO Visual Review Comments",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["id", "targetId", "page", "type", "severity", "comment", "createdAt", "status"],
    "additionalProperties": true,
    "properties": {
      "id": { "type": "string" },
      "targetId": { "type": "string", "description": "Matches data-gqo-id, or global for project-wide feedback." },
      "page": { "type": "string" },
      "scope": { "enum": ["global", "screen", "element", "flow", "project"] },
      "mode": { "enum": ["comment", "edit"] },
      "type": { "enum": ["change-request", "question", "approval", "risk"] },
      "severity": { "enum": ["low", "medium", "high"] },
      "comment": { "type": "string" },
      "createdAt": { "type": "string", "format": "date-time" },
      "savedAt": { "type": "string", "format": "date-time" },
      "status": { "enum": ["saved", "running", "applied", "failed"] },
      "failureReason": { "type": "string" }
    }
  }
}
