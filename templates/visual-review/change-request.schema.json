{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://giqo.local/schemas/change-request.schema.json",
  "title": "GIQO Visual Review Change Request",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "sourceCommentId",
    "targetId",
    "page",
    "scope",
    "requestedChange",
    "rationale",
    "acceptanceSignal",
    "priority",
    "status",
    "createdAt",
    "createdBy",
    "checks"
  ],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "sourceCommentId": { "type": "string", "minLength": 1 },
    "targetId": { "type": "string", "minLength": 1 },
    "page": { "type": "string", "minLength": 1 },
    "scope": { "enum": ["global", "screen", "element", "flow", "project"] },
    "requestedChange": { "type": "string", "minLength": 1 },
    "rationale": { "type": "string", "minLength": 1 },
    "acceptanceSignal": { "type": "string", "minLength": 1 },
    "priority": { "enum": ["low", "medium", "high"] },
    "status": { "enum": ["saved", "running", "applied", "failed"] },
    "createdAt": { "type": "string", "format": "date-time" },
    "createdBy": { "type": "string", "minLength": 1 },
    "savedAt": { "type": "string", "format": "date-time" },
    "savedBy": { "type": "string", "minLength": 1 },
    "workStartedAt": { "type": "string", "format": "date-time" },
    "assignedTo": { "type": "string", "minLength": 1 },
    "linkedTask": { "type": "string", "minLength": 1 },
    "appliedAt": { "type": "string", "format": "date-time" },
    "appliedBy": { "type": "string", "minLength": 1 },
    "changedArtifacts": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "verificationNotes": { "type": "string", "minLength": 1 },
    "failedAt": { "type": "string", "format": "date-time" },
    "failedBy": { "type": "string", "minLength": 1 },
    "failureReason": { "type": "string", "minLength": 1 },
    "implementationNotes": { "type": "string" },
    "unresolvedReportTarget": {
      "description": "Handoff document where unresolved saved, running, or failed requests are reported.",
      "type": "string",
      "const": "09_RISK_AND_DECISIONS.md"
    },
    "checks": {
      "type": "object",
      "additionalProperties": false,
      "required": ["workStart", "completion"],
      "properties": {
        "workStart": { "$ref": "#/$defs/workStartChecks" },
        "completion": { "$ref": "#/$defs/completionChecks" }
      }
    }
  },
  "allOf": [],
  "$defs": {
    "workStartChecks": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "targetConfirmed",
        "requestActionable",
        "scopeConfirmed",
        "acceptanceSignalDefined",
        "dependenciesRecorded"
      ],
      "properties": {
        "targetConfirmed": { "type": "boolean" },
        "requestActionable": { "type": "boolean" },
        "scopeConfirmed": { "type": "boolean" },
        "acceptanceSignalDefined": { "type": "boolean" },
        "dependenciesRecorded": { "type": "boolean" }
      }
    },
    "completionChecks": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifactUpdated",
        "acceptanceSignalObserved",
        "documentsAligned",
        "openQuestionsPreserved",
        "changedArtifactsRecorded"
      ],
      "properties": {
        "artifactUpdated": { "type": "boolean" },
        "acceptanceSignalObserved": { "type": "boolean" },
        "documentsAligned": { "type": "boolean" },
        "openQuestionsPreserved": { "type": "boolean" },
        "changedArtifactsRecorded": { "type": "boolean" }
      }
    },
    "workStartChecksPassed": {
      "allOf": [
        { "$ref": "#/$defs/workStartChecks" },
        {
          "properties": {
            "targetConfirmed": { "const": true },
            "requestActionable": { "const": true },
            "scopeConfirmed": { "const": true },
            "acceptanceSignalDefined": { "const": true },
            "dependenciesRecorded": { "const": true }
          }
        }
      ]
    },
    "completionChecksPassed": {
      "allOf": [
        { "$ref": "#/$defs/completionChecks" },
        {
          "properties": {
            "artifactUpdated": { "const": true },
            "acceptanceSignalObserved": { "const": true },
            "documentsAligned": { "const": true },
            "openQuestionsPreserved": { "const": true },
            "changedArtifactsRecorded": { "const": true }
          }
        }
      ]
    }
  }
}
